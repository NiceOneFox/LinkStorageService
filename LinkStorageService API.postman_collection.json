  "item": [
    {
      "name": "Create short link",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"url\":\"https://example.com\"}"
        },
        "url": {
          "raw": "http://localhost:8080/links",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "links"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get original link",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/links/{{short_code}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "links",
            "{{short_code}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get stats",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/links/{{short_code}}/stats",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "links",
            "{{short_code}}",
            "stats"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List links",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/links?limit=10&offset=0",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "links"
          ],
          "query": [
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Delete link",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/links/{{short_code}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
